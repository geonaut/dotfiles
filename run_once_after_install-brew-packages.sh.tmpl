{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# Brewfile hash: {{ includeTemplate "dot_Brewfile.tmpl" . | sha256sum }}
# This script re-runs whenever your Brewfile changes.

echo "--------------------------------------------------------"
echo "🛠️  Starting Post-Apply Setup..."
echo "--------------------------------------------------------"

if [[ "$(uname -m)" == "arm64" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
else
    eval "$(/usr/local/bin/brew shellenv)"
fi

{{ if .install_languages -}}
if command -v mise >/dev/null 2>&1; then
    echo "🚀 mise found! Installing/Updating languages (Go, Python, Rust)..."

    # This installs everything in ~/.config/mise/config.toml
    mise install --yes

    # This ensures the shims are ready for Neovim/Mason immediately
    mise reshim

    echo "✅ Languages synced via mise."
else
    echo "⚠️ mise not installed yet. It should install on the next run via Brew."
fi
{{ else -}}
echo "⏭️ Skipping language installation (opted-out in .chezmoi.toml)."
{{- end }}

echo "--------------------------------------------------------"
echo "✅ Setup complete!"
echo "--------------------------------------------------------"
{{ end -}}
