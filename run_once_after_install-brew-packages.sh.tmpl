{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

# Brewfile hash: {{ include "dot_brewfile.tmpl" | sha256sum }}
# Re-runs whenever ~/.brewfile changes (the hash above changes -> new script content).

echo "--------------------------------------------------------"
echo "🍺 Syncing Homebrew packages from ~/.brewfile ..."
echo "--------------------------------------------------------"

if [[ "$(uname -m)" == "arm64" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
else
    eval "$(/usr/local/bin/brew shellenv)"
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "❌ Homebrew not installed. Install it first: https://brew.sh"
    exit 1
fi

# Homebrew 6+ requires non-core taps to be trusted before their formulae load.
# Trust whatever taps are declared in ~/.brewfile (future-proof for new taps).
while IFS= read -r t; do
    [ -n "$t" ] && brew trust --tap "$t"
done < <(grep -E '^[[:space:]]*tap "' "$HOME/.brewfile" | sed -E 's/.*tap "([^"]+)".*/\1/')

brew bundle --file="$HOME/.brewfile"

echo "--------------------------------------------------------"
echo "✅ Homebrew packages synced."
echo "--------------------------------------------------------"
{{ end -}}
