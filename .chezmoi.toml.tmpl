[data]
    name = "geonaut"
    # Prompts for true/false. Defaults to true if you just hit enter.
    install_languages = {{ promptBoolOnce . "install_languages" "Install programming languages (Rust, Python, Go)?" true }}

    # You could even add a 'workstation' flag for more granularity
    is_server = {{ promptBoolOnce . "is_server" "Is this a headless server?" false }}
using_bazel = {{ promptBoolOnce . "using_bazel" "Will you be using Bazel?" false }}
    using_k8s = {{ promptBoolOnce . "using_k8s" "Will you be using K8s?" false }}
    using_tf = {{ promptBoolOnce . "using_tf" "Will you be using Terraform?" false }}
    will_edit_cm = {{ promptBoolOnce . "will_edit_cm" "Will you be editing these dotfiles on this machine?" false }}


{{ if eq .chezmoi.os "darwin" -}}
    scriptTempDir = "{{ .chezmoi.homeDir }}/.config/chezmoi/tmp"
{{ end -}}
