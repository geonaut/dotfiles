#!/bin/bash

{{ if .install_languages -}}
echo "🚀 Opt-in: Syncing languages with mise..."

if command -v mise >/dev/null 2>&1; then
    # 1. Install all tools defined in ~/.config/mise/config.toml
    # This replaces all the 'if ! goenv versions' logic
    mise install --yes

    # 2. Show the active versions for peace of mind
    echo "✅ Currently active versions:"
    mise ls --current
else
    echo "❌ mise not found. Please run 'brew install mise' first."
fi

echo "✅ Language environment synchronized."

{{ else -}}
echo "⏭️ Skipping language installation as per config."
{{ end -}}
